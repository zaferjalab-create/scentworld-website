<script>
// ── Page data (server-injected) ─────────────────────────
const PRODUCT = <%- JSON.stringify({ id: product.id, slug: product.slug, name: product.name, price: product.price, category: product.category, image_url: product.image_url, sizes: sizes }) %>;
const OILS = <%- JSON.stringify(oilsLite) %>;

// ── Cart (localStorage, shared shape with homepage) ─────
let cart = [];
try { cart = JSON.parse(localStorage.getItem('sw_cart') || '[]'); } catch(e) { cart = []; }
function saveCart() { localStorage.setItem('sw_cart', JSON.stringify(cart)); updateBadge(); }
function updateBadge() {
  const n = cart.reduce((s, i) => s + (i.qty || 1), 0);
  const b = document.getElementById('cartBadge');
  if (b) { b.textContent = n; b.classList.toggle('show', n > 0); }
}
updateBadge();

let qty = 1;
let selectedSize = PRODUCT.sizes ? PRODUCT.sizes[0] : null;

function changeQty(d) {
  qty = Math.max(1, qty + d);
  document.getElementById('qtyDisplay').textContent = qty;
  updateBundleTotal();
}
function selectSize(btn) {
  selectedSize = { label: btn.dataset.label, price: parseFloat(btn.dataset.price) };
  document.querySelectorAll('#sizeButtons .pd-size-btn').forEach(b => b.classList.toggle('active', b === btn));
  document.getElementById('priceDisplay').textContent = '$' + selectedSize.price.toFixed(2);
  document.getElementById('sizeLabel').textContent = selectedSize.label;
}
function selectThumb(el) {
  document.getElementById('mainImg').src = el.dataset.src;
  document.querySelectorAll('.pd-thumb').forEach(t => t.classList.toggle('active', t === el));
}
function toggleDropdown(id) { document.getElementById(id).classList.toggle('open'); }
document.addEventListener('click', e => {
  ['oilDropdown', 'bundleOilDropdown'].forEach(id => {
    const dd = document.getElementById(id);
    if (dd && !dd.contains(e.target)) dd.classList.remove('open');
  });
});
function toggleAcc(btn) {
  const acc = btn.closest('.pd-acc');
  const ans = acc.querySelector('.pd-acc-a');
  if (acc.classList.contains('open')) { acc.classList.remove('open'); ans.style.maxHeight = '0'; }
  else { acc.classList.add('open'); ans.style.maxHeight = ans.scrollHeight + 'px'; }
}

// ── Bundle (diffuser pages) ─────────────────────────────
let bundleEnabled = false, bundleOil = OILS[0] || null, bundleSize = null;
function toggleOilBundle() {
  bundleEnabled = document.getElementById('addOilToggle').checked;
  const opts = document.getElementById('oilBundleOptions');
  const sw = document.getElementById('bundleSwitch'), dot = document.getElementById('bundleSwitchDot');
  if (bundleEnabled) {
    opts.style.display = 'block';
    sw.style.background = 'var(--gold)'; sw.style.borderColor = 'var(--gold)';
    dot.style.background = 'var(--bg)'; dot.style.left = '23px';
    if (bundleOil) selectBundleOil(bundleOil.slug);
  } else {
    opts.style.display = 'none';
    sw.style.background = 'var(--bg)'; sw.style.borderColor = 'var(--bdr)';
    dot.style.background = 'var(--txt)'; dot.style.left = '2px';
  }
  updateBundleTotal();
}
function selectBundleOil(slug) {
  bundleOil = OILS.find(o => o.slug === slug) || OILS[0];
  document.getElementById('bundleOilCurrent').textContent = bundleOil.name;
  document.getElementById('bundleOilMenu').innerHTML = OILS.map(o => `
    <div class="pd-dropdown-item ${o.slug === bundleOil.slug ? 'current' : ''}" onclick="selectBundleOil('${o.slug}');toggleDropdown('bundleOilDropdown')">
      <div class="item-thumb">${o.image_url ? `<img src="${o.image_url}" alt="" onerror="this.onerror=null;this.src='/images/placeholder.svg'">` : ''}</div>
      <div class="item-name">${o.name}</div>
      <div class="item-price">from $${(o.price || 0).toFixed(2)}</div>
    </div>`).join('');
  const sizes = bundleOil.sizes || [];
  bundleSize = sizes[0] || null;
  document.getElementById('bundleSizeButtons').innerHTML = sizes.map((s, i) => `
    <button class="pd-size-btn ${i === 0 ? 'active' : ''}" data-i="${i}" onclick="selectBundleSize(this)">
      <span class="sz-vol">${s.label}</span><span class="sz-price">+$${s.price.toFixed(2)}</span>
    </button>`).join('');
  updateBundleTotal();
}
function selectBundleSize(btn) {
  bundleSize = bundleOil.sizes[parseInt(btn.dataset.i)];
  document.querySelectorAll('#bundleSizeButtons .pd-size-btn').forEach(b => b.classList.toggle('active', b === btn));
  updateBundleTotal();
}
function updateBundleTotal() {
  const el = document.getElementById('bundleTotal');
  if (!el) return;
  let t = (selectedSize ? selectedSize.price : (PRODUCT.price || 0)) * qty;
  if (bundleEnabled && bundleSize) t += bundleSize.price * qty;
  el.textContent = '$' + t.toFixed(2);
}

// ── Add to cart ─────────────────────────────────────────
function addToCart() {
  const sizeLabel = selectedSize ? selectedSize.label : null;
  const price = selectedSize ? selectedSize.price : (PRODUCT.price || 0);
  const key = sizeLabel ? `${PRODUCT.id}-${sizeLabel}` : String(PRODUCT.id);
  const ex = cart.find(i => i.cartKey === key);
  if (ex) ex.qty += qty;
  else cart.push({ cartKey: key, id: PRODUCT.id, slug: PRODUCT.slug, name: PRODUCT.name + (sizeLabel ? ` (${sizeLabel})` : ''), price, category: PRODUCT.category, size: sizeLabel, image_url: PRODUCT.image_url, qty });

  let bundleMsg = '';
  if (bundleEnabled && bundleOil && bundleSize) {
    const ok = `${bundleOil.id}-${bundleSize.label}`;
    const exO = cart.find(i => i.cartKey === ok);
    if (exO) exO.qty += qty;
    else cart.push({ cartKey: ok, id: bundleOil.id, slug: bundleOil.slug, name: `${bundleOil.name} (${bundleSize.label})`, price: bundleSize.price, category: 'oils', size: bundleSize.label, image_url: bundleOil.image_url, qty });
    bundleMsg = ` + ${bundleOil.name} (${bundleSize.label})`;
  }
  saveCart();

  if (typeof gtag === 'function') gtag('event', 'add_to_cart', { currency: 'CAD', value: price * qty, items: [{ item_id: PRODUCT.id, item_name: PRODUCT.name, item_variant: sizeLabel || '', item_category: PRODUCT.category, price, quantity: qty }] });
  if (typeof fbq === 'function') fbq('track', 'AddToCart', { currency: 'CAD', value: price * qty, content_ids: [PRODUCT.id], content_name: PRODUCT.name, content_type: 'product' });

  const btn = document.getElementById('atcBtn');
  btn.classList.add('added');
  btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Added to Cart';
  showToast(`Added ${qty} × ${PRODUCT.name}${sizeLabel ? ` (${sizeLabel})` : ''}${bundleMsg} to cart`);
  setTimeout(() => {
    btn.classList.remove('added');
    btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg> Add to Cart';
  }, 2500);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

// ── Cart drawer ─────────────────────────────────────────
function openCartDrawer(e) {
  if (e) { e.preventDefault(); e.stopPropagation(); }
  renderCartBody();
  document.getElementById('cartOverlay').classList.add('open');
  document.getElementById('cartDrawer').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeCart() {
  document.getElementById('cartOverlay').classList.remove('open');
  document.getElementById('cartDrawer').classList.remove('open');
  document.body.style.overflow = '';
}
function renderCartBody() {
  const body = document.getElementById('cartBody');
  const foot = document.getElementById('cartFoot');
  if (!cart.length) {
    body.innerHTML = `<div class="cart-empty"><svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg><p>Your cart is empty.</p><a href="/shop" onclick="closeCart()">Continue Shopping</a></div>`;
    foot.style.display = 'none';
    return;
  }
  body.innerHTML = cart.map(item => {
    const key = item.cartKey || String(item.id);
    return `<div class="cart-item">
      <div class="ci-icon">${item.image_url ? `<img src="${item.image_url}" alt="" onerror="this.onerror=null;this.src='/images/placeholder.svg'">` : ''}</div>
      <div class="ci-info">
        <div class="ci-name" title="${item.name}">${item.name}</div>
        <div class="ci-price">$${(item.price * item.qty).toFixed(2)} CAD</div>
        <div class="ci-qty">
          <button class="qty-btn" onclick="cartQty('${key}',-1)">&#8722;</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="cartQty('${key}',1)">+</button>
        </div>
      </div>
      <button class="ci-rm" onclick="cartRm('${key}')" title="Remove">&times;</button>
    </div>`;
  }).join('');
  const sub = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('cartSubtotal').textContent = `$${sub.toFixed(2)} CAD`;
  document.getElementById('cartShipping').textContent = sub >= 150 ? 'FREE' : 'Calculated at checkout';
  document.getElementById('cartTotal').textContent = `$${sub.toFixed(2)} CAD`;
  foot.style.display = 'block';
}
function cartQty(key, d) {
  const it = cart.find(i => (i.cartKey || String(i.id)) === String(key));
  if (!it) return;
  it.qty = Math.max(0, it.qty + d);
  if (it.qty === 0) return cartRm(key);
  saveCart(); renderCartBody();
}
function cartRm(key) {
  cart = cart.filter(i => (i.cartKey || String(i.id)) !== String(key));
  saveCart(); renderCartBody();
}
document.getElementById('cartBtn').addEventListener('click', openCartDrawer);
document.getElementById('checkoutBtn').addEventListener('click', async function() {
  if (!cart.length) return;
  this.disabled = true; this.textContent = 'Processing…';
  if (typeof gtag === 'function') {
    const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
    gtag('event', 'begin_checkout', { currency: 'CAD', value: total, items: cart.map(i => ({ item_id: i.id, item_name: i.name, item_variant: i.size || '', item_category: i.category, price: i.price, quantity: i.qty })) });
  }
  if (typeof fbq === 'function') {
    const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
    fbq('track', 'InitiateCheckout', { currency: 'CAD', value: total, num_items: cart.reduce((s, i) => s + i.qty, 0), content_ids: cart.map(i => i.id) });
  }
  try {
    const res = await fetch('/api/checkout', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: cart.map(i => ({ id: i.id, quantity: i.qty, size: i.size || null })) }),
    });
    const data = await res.json();
    if (data.success && data.url) { cart = []; saveCart(); window.location.href = data.url; }
    else throw new Error(data.error || 'Checkout failed');
  } catch (err) {
    alert('Something went wrong. Please try again.');
    this.disabled = false; this.textContent = 'Proceed to Checkout';
  }
});

// ── Zoom ────────────────────────────────────────────────
function openZoom() {
  document.getElementById('zoomImg').src = document.getElementById('mainImg').src;
  document.getElementById('zoomOverlay').classList.add('open');
}
function closeZoom() { document.getElementById('zoomOverlay').classList.remove('open'); }
document.getElementById('zoomOverlay').addEventListener('click', e => { if (e.target.id === 'zoomOverlay') closeZoom(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeZoom(); closeCart(); } });

// GA4 view_item
if (typeof gtag === 'function') gtag('event', 'view_item', { currency: 'CAD', value: selectedSize ? selectedSize.price : (PRODUCT.price || 0), items: [{ item_id: PRODUCT.id, item_name: PRODUCT.name, item_category: PRODUCT.category, price: selectedSize ? selectedSize.price : PRODUCT.price }] });
</script>
</body>
</html>
