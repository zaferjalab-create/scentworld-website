<%
// ── Server-side data prep ──────────────────────────────
const CAT_LABELS = { diffusers: 'Scent Diffusers', oils: 'Fragrance Oils', home_car: 'Home & Car', aerosol: 'Aerosol Systems' };
const catLabel = CAT_LABELS[product.category] || 'Products';

let sizes = null;
try { const s = JSON.parse(product.sizes || 'null'); if (Array.isArray(s) && s.length) sizes = s; } catch(e) {}

let gallery = [];
try { const g = JSON.parse(product.gallery_images || '[]'); if (Array.isArray(g)) gallery = g; } catch(e) {}
const images = [];
if (product.image_url) images.push(product.image_url);
for (const g of gallery) if (g && !images.includes(g) && images.length < 6) images.push(g);

let box = [];
try { const b = JSON.parse(product.box_contents || '[]'); if (Array.isArray(b)) box = b; } catch(e) {}

const specs = [
  ['Coverage area', product.spec_coverage || product.coverage],
  ['Oil capacity', product.spec_oil_capacity],
  ['Noise level', product.spec_noise],
  ['Power supply', product.spec_power],
  ['Dimensions', product.spec_dimensions],
  ['Weight', product.spec_weight],
  ['Warranty', product.spec_warranty],
].filter(([k, v]) => v && String(v).trim());

const startPrice = sizes ? sizes[0].price : (product.price || 0);
const minPrice = sizes ? Math.min(...sizes.map(s => s.price)) : (product.price || 0);
const maxPrice = sizes ? Math.max(...sizes.map(s => s.price)) : (product.price || 0);
const isOil = product.category === 'oils';
const isDiffuser = product.category === 'diffusers';
const metaDesc = (product.short_desc || product.name) + ' Ships from Halifax. Free shipping over $150 CAD across Canada.';
const BASE = 'https://www.scentworld.ca';
const pageUrl = BASE + '/products/' + product.slug;
const imgAbs = u => u && u.startsWith('http') ? u : BASE + (u || '/images/logo.png');

const oilsLite = oils.map(o => {
  let os = null; try { const t = JSON.parse(o.sizes || 'null'); if (Array.isArray(t) && t.length) os = t; } catch(e) {}
  return { id: o.id, slug: o.slug, name: o.name, image_url: o.image_url, price: o.price, sizes: os };
});
%><!DOCTYPE html>
