    <a href="https://g.page/r/CVI4mIs6HAAREBM/review" target="_blank" rel="noopener">Read Google Reviews</a>
  </div>
</div>

<% if (related.length) { %>
<div class="pd-section" style="padding-bottom:5rem">
  <h2>You may also <em>like</em></h2>
  <div class="rel-row">
    <% related.forEach(r => { %>
    <a href="/products/<%= r.slug %>" class="rel-card">
      <div class="rel-img"><img src="<%= r.image_url || '/images/placeholder.svg' %>" alt="<%= r.name %>" loading="lazy" onerror="this.onerror=null;this.src='/images/placeholder.svg'"></div>
      <div class="rel-body">
        <div class="rel-cat"><%= CAT_LABELS[r.category] || r.category %></div>
        <div class="rel-name"><%= r.name %></div>
        <div class="rel-price">$<%= (r.price || 0).toFixed(2) %><% let rs=null; try{rs=JSON.parse(r.sizes||'null')}catch(e){}; if (Array.isArray(rs) && rs.length>1) { %><span style="color:var(--txt);font-size:.7rem;font-family:var(--bf)"> +</span><% } %></div>
      </div>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

