<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0b0908;--bg2:#12100e;--bg3:#1a1714;--bg4:#211e1a;--gold:#c9a55c;--gold-l:#e0ca8e;--cream:#f5f0e6;--cream2:#cdc5b8;--txt:#958e85;--txt2:#635d55;--bdr:rgba(201,165,92,.1);--df:'Playfair Display',serif;--bf:'Outfit',sans-serif}
html{scroll-behavior:smooth}body{font-family:var(--bf);background:var(--bg);color:var(--cream);overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:var(--gold);text-decoration:none}
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.3rem 4vw;display:flex;align-items:center;justify-content:space-between;background:rgba(11,9,8,.93);backdrop-filter:blur(25px);border-bottom:1px solid var(--bdr)}
.nl span{font-family:var(--df);font-size:1.2rem;color:var(--gold);letter-spacing:.06em}


.hero-bg{position:relative;height:65vh;min-height:480px;overflow:hidden;display:flex;align-items:flex-end;padding:0 4vw 5rem}
.hero-bg::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(11,9,8,.35) 0,rgba(11,9,8,.95) 100%);z-index:1}
.hero-bg img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
.hero-content{position:relative;z-index:2;max-width:900px}
.hero-ind{font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem}
.hero-content h1{font-family:var(--df);font-size:clamp(2.5rem,5vw,4rem);font-weight:500;line-height:1.1;margin-bottom:1.5rem}
.hero-content h1 em{color:var(--gold);font-style:italic;font-weight:400}
.hero-content p{font-size:1.05rem;color:var(--cream2);font-weight:300;line-height:1.7;max-width:620px}
.section{padding:6rem 4vw}.section-inner{max-width:1200px;margin:0 auto}
.sl{font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:inline-flex;align-items:center;gap:.7rem}
.sl::before{content:'';width:30px;height:1px;background:var(--gold)}
h2{font-family:var(--df);font-size:clamp(1.8rem,3vw,2.6rem);font-weight:400;line-height:1.2;margin-bottom:1.5rem}h2 em{color:var(--gold);font-style:italic}
.lead{font-size:1.05rem;color:var(--cream2);font-weight:300;line-height:1.85;max-width:760px;margin-bottom:2rem}
.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.8rem;margin-top:3rem}
.card{background:var(--bg2);border:1px solid var(--bdr);padding:2rem 1.8rem;transition:all .4s}
.card:hover{border-color:rgba(201,165,92,.3);transform:translateY(-4px)}
.card-num{font-family:var(--df);font-size:.95rem;color:var(--gold);font-style:italic;margin-bottom:1rem}
.card h3{font-family:var(--df);font-size:1.25rem;font-weight:500;color:var(--cream);margin-bottom:.8rem}
.card p{font-size:.92rem;line-height:1.75;color:var(--cream2);font-weight:300}
.alt-bg{background:var(--bg2)}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2rem;margin:3rem 0;padding:3rem 2rem;background:var(--bg3);border:1px solid var(--bdr);border-radius:2px;text-align:center}
.stat-val{font-family:var(--df);font-size:2.8rem;color:var(--gold);font-weight:500;line-height:1;margin-bottom:.4rem}
.stat-lbl{font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--txt);font-weight:300}
.zones{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;margin-top:2.5rem}
.zone{padding:1.8rem;background:var(--bg3);border-left:3px solid var(--gold)}
.zone h4{font-family:var(--df);font-size:1.1rem;color:var(--gold);margin-bottom:.6rem;font-weight:500}
.zone p{font-size:.9rem;line-height:1.7;color:var(--cream2);font-weight:300}
.cta{background:linear-gradient(135deg,var(--bg2) 0,var(--bg3) 100%);border:1px solid rgba(201,165,92,.25);padding:4rem 3rem;text-align:center;border-radius:2px;margin:3rem 0 0}
.cta h2{margin-bottom:1.2rem;color:var(--cream)}.cta p{font-size:1rem;color:var(--cream2);margin-bottom:2rem;font-weight:300;max-width:620px;margin-left:auto;margin-right:auto}
.cta-btn{display:inline-block;padding:1rem 2.5rem;background:var(--gold);color:var(--bg);text-decoration:none;font-size:.7rem;letter-spacing:.28em;text-transform:uppercase;font-weight:500;transition:all .3s;margin:0 .4rem}
.cta-btn:hover{background:var(--gold-l)}
.cta-btn-ghost{background:none;color:var(--gold);border:1px solid var(--gold)}
.cta-btn-ghost:hover{background:var(--gold);color:var(--bg)}
footer{background:var(--bg2);border-top:1px solid var(--bdr);padding:2.5rem 4vw;text-align:center}
.fb p{font-size:.72rem;color:var(--txt2);letter-spacing:.06em}.fb a{color:var(--txt);font-size:.72rem;letter-spacing:.06em;margin:0 .8rem}.fb a:hover{color:var(--gold)}
.fb-links{margin-top:.7rem}
</style>
</head>
<body>

<%- include('../partials/header', {cartLive: false}) %>

<section class="hero-bg">
  <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=1920&q=80&auto=format" alt="Tranquil spa with candles and aromatherapy">
  <div class="hero-content">
    <div class="hero-ind">For Spas &amp; Wellness</div>
    <h1>Where Calm Becomes <em>Tangible</em></h1>
    <p>Professional aromatherapy and scent diffusion solutions for spas, wellness centres, yoga studios, and medical wellness facilities. Calibrated for the relaxation journey.</p>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="sl">Why It Matters</div>
    <h2>Scent Is Your Treatment's <em>Invisible Co-Therapist</em></h2>
    <p class="lead">Your treatments are what clients pay for — but atmosphere is what makes them return. Research consistently shows that ambient scenting in wellness environments deepens relaxation, reduces stress markers, extends treatment satisfaction, and dramatically improves rebooking rates.</p>
    <div class="stats-row">
      <div><div class="stat-val">+45%</div><div class="stat-lbl">Relaxation Response</div></div>
      <div><div class="stat-val">−38%</div><div class="stat-lbl">Cortisol Levels</div></div>
      <div><div class="stat-val">+27%</div><div class="stat-lbl">Rebooking Rate</div></div>
      <div><div class="stat-val">+22%</div><div class="stat-lbl">Retail Sales</div></div>
    </div>
  </div>
</section>

<section class="section alt-bg">
  <div class="section-inner">
    <div class="sl">Spa Scent Programs</div>
    <h2>Scenting Every <em>Touchpoint</em></h2>
    <div class="zones">
      <div class="zone"><h4>Reception</h4><p>Your brand's signature scent — the first sensory impression clients carry into their entire visit. Sets the tone for relaxation.</p></div>
      <div class="zone"><h4>Treatment Rooms</h4><p>Therapy-supportive light scenting that complements (never overpowers) your essential oils, lotions, and treatments.</p></div>
      <div class="zone"><h4>Relaxation Lounge</h4><p>Calming neutral blends — lavender, chamomile, soft amber — that extend the post-treatment relaxation experience.</p></div>
      <div class="zone"><h4>Steam &amp; Sauna</h4><p>Heat-stable formulations including eucalyptus and pine for thermal therapy zones.</p></div>
      <div class="zone"><h4>Retail Display</h4><p>Strategic scenting that supports retail purchases of your candles, oils, and aromatherapy products.</p></div>
      <div class="zone"><h4>Locker Rooms</h4><p>Fresh, clean profiles that mask gym-adjacent odours and signal hygiene.</p></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="sl">Wellness Scent Library</div>
    <h2>Curated for <em>Therapeutic Atmosphere</em></h2>
    <p class="lead">Our wellness collection includes professionally formulated scent profiles designed for spa environments. All formulations are IFRA-compliant, hypoallergenic-friendly, and built on therapeutic-grade essential oils.</p>
    <div class="grid-3">
      <div class="card"><div class="card-num">Calm</div><h3>Lavender Sanctuary</h3><p>Pure French lavender with hints of chamomile and bergamot. The classic relaxation profile.</p></div>
      <div class="card"><div class="card-num">Fresh</div><h3>Eucalyptus Mountain</h3><p>Crisp eucalyptus with pine and mint. Energizing for steam rooms and morning programs.</p></div>
      <div class="card"><div class="card-num">Earth</div><h3>Cedarwood Forest</h3><p>Grounding cedar with vetiver and sandalwood. Deeply meditative.</p></div>
      <div class="card"><div class="card-num">Bright</div><h3>Citrus Awakening</h3><p>Bergamot, grapefruit, and neroli. Uplifting for treatment rooms.</p></div>
      <div class="card"><div class="card-num">Warm</div><h3>Amber Honey</h3><p>Soft amber with vanilla and honey. Cocooning warmth.</p></div>
      <div class="card"><div class="card-num">Bespoke</div><h3>Your Signature</h3><p>Custom-developed signature scent unique to your wellness brand. Trademark-protectable.</p></div>
    </div>
  </div>
</section>

<section class="section alt-bg">
  <div class="section-inner" style="max-width:820px;text-align:center">
    <div class="sl" style="justify-content:center">Industry Insights</div>
    <h2>Learn More About <em>Spa Scent Marketing</em></h2>
    <p class="lead" style="margin-left:auto;margin-right:auto;text-align:center">Explore our guides on diffuser selection, fragrance design, and wellness scent strategy.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2rem">
      <a href="/blog/choosing-spa-diffuser.html" class="cta-btn cta-btn-ghost">Spa Diffuser Guide →</a>
      <a href="/blog/custom-signature-scent-guide.html" class="cta-btn cta-btn-ghost">Custom Scent Guide →</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="cta">
      <h2>Elevate Your <em>Wellness Experience</em></h2>
      <p>Schedule a free 30-minute consultation. We'll assess your space and recommend a scent program designed to deepen relaxation, increase rebookings, and elevate your brand.</p>
      <a href="/#booking" class="cta-btn">Book Free Consultation</a>
      <a href="/#contact" class="cta-btn cta-btn-ghost">Request a Quote</a>
    </div>
  </div>
</section>

