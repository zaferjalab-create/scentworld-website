<style>
.google-badge{display:inline-flex;align-items:center;gap:.65rem;margin-top:1.4rem;padding:.65rem 1rem .65rem .85rem;background:var(--bg3);border:1px solid var(--bdr);border-radius:30px;text-decoration:none;transition:all .35s;max-width:fit-content}
.google-badge:hover{border-color:var(--gold);background:var(--bg4);transform:translateY(-2px);box-shadow:0 6px 20px rgba(201,165,92,.12)}
.google-badge svg{flex-shrink:0}
.gb-txt{display:flex;flex-direction:column;line-height:1.1}
.gb-lbl{font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:var(--txt);font-weight:300}
.gb-txt strong{font-size:.82rem;color:var(--cream);font-weight:500;letter-spacing:.02em;font-family:var(--bf)}
.gb-txt strong{background:linear-gradient(90deg,var(--cream) 0,var(--cream) 55%,#f5b400 55%,#f5b400 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.google-badge:hover .gb-txt strong{background:linear-gradient(90deg,var(--gold) 0,var(--gold) 55%,#f5b400 55%,#f5b400 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
footer{background:var(--bg2);padding:4rem 4vw 1.5rem;border-top:1px solid var(--bdr)}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem}
.ftb p{font-size:.78rem;font-weight:200;line-height:1.7;color:var(--txt);max-width:280px;margin-top:.8rem}
.ftc h4{font-family:var(--df);font-size:.95rem;font-weight:500;margin-bottom:1.2rem}
.ftc ul{list-style:none}
.ftc ul li{margin-bottom:.6rem}
.ftc ul li a{font-size:.75rem;font-weight:200;color:var(--txt);text-decoration:none;transition:color .3s}
.ftc ul li a:hover{color:var(--gold)}
.fb{display:flex;justify-content:space-between;align-items:center;padding-top:1.5rem;border-top:1px solid var(--bdr);flex-wrap:wrap;gap:.8rem}
.fb p{font-size:.65rem;color:var(--txt2);font-weight:200}
.fb a{color:var(--gold);text-decoration:none}
.fs{display:flex;gap:1rem}
.fs a{width:32px;height:32px;border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;color:var(--txt);text-decoration:none;font-size:.65rem;transition:all .3s}
.fs a:hover{border-color:var(--gold);color:var(--gold)}
@media(max-width:1024px){.ft{grid-template-columns:1fr 1fr}}
@media(max-width:768px){.ft{grid-template-columns:1fr;gap:1.5rem}}
</style>
