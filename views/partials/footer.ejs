<script>
(function() {
  document.addEventListener('error', function(e) {
    var t = e.target;
    if (t && t.tagName === 'IMG' && !t.dataset.fbk) { t.dataset.fbk = '1'; t.src = '/images/placeholder.svg'; }
  }, true);
  window.addEventListener('load', function() {
    document.querySelectorAll('img').forEach(function(im) {
      if (im.complete && im.naturalWidth === 0 && !im.dataset.fbk) { im.dataset.fbk = '1'; im.src = '/images/placeholder.svg'; }
    });
  });
  try {
    var c = JSON.parse(localStorage.getItem('sw_cart') || '[]');
    var n = c.reduce(function(s, i) { return s + (i.qty || 1); }, 0);
    // Exclude .wish-count — that badge is driven by the wishlist, not the cart.
    document.querySelectorAll('.cart-badge:not(.wish-count)').forEach(function(b) {
      b.textContent = n; if (n > 0) b.classList.add('show');
    });
  } catch (e) {}
})();
</script>

<!-- Email capture — first-order incentive (tasteful, once per visitor) -->
<div class="sw-pop" id="swPop" aria-hidden="true">
  <div class="sw-pop-card" role="dialog" aria-label="Save 10% on your first order">
    <button class="sw-pop-x" id="swPopX" aria-label="Close">&times;</button>
    <div class="sw-pop-eyebrow">Welcome offer</div>
    <h3 class="sw-pop-h">Save <em>10%</em> on your first order</h3>
    <p class="sw-pop-p">Join our list for early access to new fragrances, seasonal collections, and a code for 10% off your first purchase.</p>
    <form class="sw-pop-form" id="swPopForm">
      <input type="email" id="swPopEmail" placeholder="you@email.com" required aria-label="Email address">
      <button type="submit">Get my code</button>
    </form>
    <p class="sw-pop-note" id="swPopNote">No spam — unsubscribe anytime.</p>
  </div>
</div>
<style>
.sw-pop{position:fixed;inset:0;z-index:2000;display:none;align-items:center;justify-content:center;padding:1.2rem;
  background:rgba(6,5,4,.72);backdrop-filter:blur(4px);opacity:0;transition:opacity .35s}
.sw-pop.show{display:flex;opacity:1}
.sw-pop-card{position:relative;max-width:420px;width:100%;background:var(--bg2,#12100e);border:1px solid var(--gold,#c9a55c);
  border-radius:3px;padding:2.4rem 2rem 2rem;text-align:center;box-shadow:0 30px 80px rgba(0,0,0,.6);
  transform:translateY(14px);transition:transform .4s cubic-bezier(.16,1,.3,1)}
.sw-pop.show .sw-pop-card{transform:translateY(0)}
.sw-pop-x{position:absolute;top:.7rem;right:.9rem;background:none;border:none;color:var(--txt,#958e85);font-size:1.5rem;cursor:pointer;line-height:1;transition:color .3s}
.sw-pop-x:hover{color:var(--gold,#c9a55c)}
.sw-pop-eyebrow{font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold,#c9a55c);margin-bottom:.9rem}
.sw-pop-h{font-family:var(--df,'Playfair Display',serif);font-size:1.7rem;font-weight:500;color:var(--cream,#f5f0e6);line-height:1.2;margin-bottom:.7rem}
.sw-pop-h em{font-style:italic;color:var(--gold,#c9a55c)}
.sw-pop-p{font-size:.85rem;font-weight:300;color:var(--cream2,#cdc5b8);line-height:1.6;margin-bottom:1.4rem}
.sw-pop-form{display:flex;gap:.5rem;flex-wrap:wrap}
.sw-pop-form input{flex:1;min-width:0;padding:.8rem 1rem;background:var(--bg,#0b0908);border:1px solid var(--bdr,rgba(201,165,92,.1));
  color:var(--cream,#f5f0e6);font-family:var(--bf,'Outfit',sans-serif);font-size:.85rem;outline:none;transition:border-color .3s}
.sw-pop-form input:focus{border-color:var(--gold,#c9a55c)}
.sw-pop-form button{padding:.8rem 1.4rem;background:var(--gold,#c9a55c);color:var(--bg,#0b0908);border:none;cursor:pointer;
  font-family:var(--bf,'Outfit',sans-serif);font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;font-weight:600;transition:background .3s}
.sw-pop-form button:hover{background:var(--gold-l,#e0ca8e)}
.sw-pop-note{font-size:.7rem;color:var(--txt,#958e85);font-weight:300;margin-top:.9rem}
.sw-pop-code{display:inline-block;margin-top:.4rem;font-family:var(--df,serif);font-size:1.3rem;letter-spacing:.12em;color:var(--gold,#c9a55c);border:1px dashed var(--gold,#c9a55c);padding:.3rem 1rem;border-radius:3px}
@media(max-width:480px){.sw-pop-form{flex-direction:column}.sw-pop-form button{width:100%}}
</style>
<script>
(function () {
  var KEY = 'sw_pop_seen';
  var pop = document.getElementById('swPop');
  if (!pop) return;
  var seen = false;
  try { seen = localStorage.getItem(KEY) === '1' || (JSON.parse(localStorage.getItem('sw_subscribed') || 'false')); } catch (e) {}
  if (seen) return;
  var opened = false;
  function open() {
    if (opened) return; opened = true;
    pop.classList.add('show'); pop.setAttribute('aria-hidden', 'false');
  }
  function dismiss() {
    pop.classList.remove('show'); pop.setAttribute('aria-hidden', 'true');
    try { localStorage.setItem(KEY, '1'); } catch (e) {}
  }
  // Show after 12s, or on exit-intent (mouse leaves toward the top).
  var t = setTimeout(open, 12000);
  document.addEventListener('mouseout', function (e) {
    if (e.clientY <= 0 && !e.relatedTarget) { clearTimeout(t); open(); }
  });
  document.getElementById('swPopX').addEventListener('click', dismiss);
  pop.addEventListener('click', function (e) { if (e.target === pop) dismiss(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && pop.classList.contains('show')) dismiss(); });
  document.getElementById('swPopForm').addEventListener('submit', function (e) {
    e.preventDefault();
    var email = document.getElementById('swPopEmail').value.trim();
    var note = document.getElementById('swPopNote');
    var btn = e.target.querySelector('button');
    btn.disabled = true; btn.textContent = '…';
    fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: email, source: 'popup' }) })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d && d.success) {
          try { localStorage.setItem('sw_subscribed', 'true'); localStorage.setItem(KEY, '1'); } catch (e) {}
          e.target.style.display = 'none';
          note.innerHTML = 'You\'re in! Use this at checkout:<br><span class="sw-pop-code">WELCOME10</span>';
          if (typeof gtag === 'function') gtag('event', 'sign_up', { method: 'popup' });
        } else {
          note.textContent = (d && d.error) || 'Something went wrong — please try again.';
          btn.disabled = false; btn.textContent = 'Get my code';
        }
      })
      .catch(function () { note.textContent = 'Connection error — please try again.'; btn.disabled = false; btn.textContent = 'Get my code'; });
  });
})();
</script>
