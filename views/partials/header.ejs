<style>
:root{
  --bg:#0b0908;--bg2:#12100e;--bg3:#1a1714;--bg4:#211e1a;
  --gold:#c9a55c;--gold-l:#e0ca8e;--gold-d:#9a7d3e;
  --cream:#f5f0e6;--cream2:#cdc5b8;
  --txt:#958e85;--txt2:#635d55;
  --bdr:rgba(201,165,92,.1);--bdr2:rgba(255,255,255,0.06);
  --err:#c0392b;--ok:#27ae60;
  --df:'Playfair Display',serif;--bf:'Outfit',sans-serif;
}
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.3rem 4vw;display:flex;align-items:center;justify-content:space-between;transition:all .5s}
nav.sc{background:rgba(11,9,8,.93);backdrop-filter:blur(25px);padding:.85rem 4vw;border-bottom:1px solid var(--bdr)}
.nl img{height:34px;transition:height .3s}
nav.sc .nl img{height:28px}
.nk{display:flex;gap:2.5rem;align-items:center}
.nk a{font-size:.66rem;letter-spacing:.28em;text-transform:uppercase;color:var(--cream2);text-decoration:none;font-weight:300;position:relative;transition:color .3s}
.nk a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .4s}
.nk a:hover{color:var(--gold)}
.nk a:hover::after{width:100%}
.nc{padding:.55rem 1.6rem!important;border:1px solid var(--gold)!important;color:var(--gold)!important;transition:all .4s!important}
.nc:hover{background:var(--gold)!important;color:var(--bg)!important}
.nc::after{display:none!important}
.mb{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:5px}
.mb span{width:22px;height:1px;background:var(--gold)}
.mn{position:fixed;inset:0;z-index:999;background:rgba(11,9,8,.97);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.8rem;opacity:0;visibility:hidden;transition:all .4s}
.mn.op{opacity:1;visibility:visible}
.mn a{font-family:var(--df);font-size:1.8rem;font-weight:400;color:var(--cream);text-decoration:none;transition:color .3s}
.mn a:hover{color:var(--gold)}
.mc{position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:var(--gold);font-size:1.3rem;cursor:pointer}
.cart-btn{position:relative;background:none;border:none;cursor:pointer;color:var(--cream2);padding:4px 8px;display:flex;align-items:center;gap:.4rem;transition:color .3s}
.cart-btn:hover{color:var(--gold)}
.cart-btn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.5}
.cart-badge{position:absolute;top:-5px;right:-5px;background:var(--gold);color:var(--bg);font-size:.5rem;font-weight:700;width:17px;height:17px;border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .3s}
.cart-badge.show{opacity:1}
.m-actions{display:flex;align-items:center;gap:.2rem}
.m-actions .cart-btn,.m-actions .mb{display:none}
@media(max-width:768px){.nk{display:none}.m-actions .cart-btn{display:flex}.m-actions .mb{display:flex}.m-actions{gap:.6rem}}
a.cart-btn{text-decoration:none}
/* Search */
.nav-search{display:flex;align-items:center;position:relative}
.nav-search-btn{background:none;border:none;cursor:pointer;color:var(--cream2);padding:4px 6px;display:flex;align-items:center;transition:color .3s}
.nav-search-btn:hover{color:var(--gold)}
.nav-search-btn svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.6}
.nav-search-form{position:absolute;right:0;top:calc(100% + 12px);display:none;flex-direction:column;background:var(--bg2);border:1px solid var(--gold);padding:.4rem;border-radius:2px;box-shadow:0 14px 40px rgba(0,0,0,.5);width:290px}
.nav-search.open .nav-search-form{display:flex}
.nav-search-row{display:flex}
.nav-search-form input{flex:1;padding:.6rem .8rem;background:transparent;border:none;outline:none;color:var(--cream);font-family:var(--bf);font-size:.82rem}
.nav-search-form input::placeholder{color:var(--txt2)}
.nav-search-form .go-btn{padding:.55rem 1rem;background:var(--gold);color:var(--bg);border:none;cursor:pointer;font-family:var(--bf);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;font-weight:500}
.mn-search{display:flex;width:min(78vw,320px);margin-bottom:.4rem;background:var(--bg2);border:1px solid var(--bdr);border-radius:2px}
.mn-search input{flex:1;padding:.75rem .9rem;background:transparent;border:none;outline:none;color:var(--cream);font-family:var(--bf);font-size:.88rem}
.mn-search button{padding:.6rem 1rem;background:var(--gold);color:var(--bg);border:none;cursor:pointer;font-size:.85rem}
/* Live search suggestions dropdown (shared desktop + mobile) */
.search-suggest{display:none;flex-direction:column;margin-top:.35rem}
.search-suggest.show{display:flex}
.mn-suggest{width:min(78vw,320px);max-height:46vh;overflow-y:auto}
.search-suggest a{display:flex;align-items:center;gap:.7rem;padding:.5rem .55rem;text-decoration:none;border-radius:2px;transition:background .2s}
.search-suggest a:hover{background:var(--bg3)}
.search-suggest img{width:38px;height:38px;object-fit:cover;border-radius:3px;background:var(--bg4);flex-shrink:0}
.ss-info{display:flex;flex-direction:column;min-width:0}
.ss-name{font-family:var(--bf);font-size:.8rem;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ss-meta{font-size:.62rem;letter-spacing:.06em;color:var(--txt);text-transform:uppercase}
.ss-price{margin-left:auto;font-family:var(--df);font-size:.85rem;color:var(--gold);flex-shrink:0;padding-left:.4rem}
.ss-empty{padding:.6rem .55rem;font-size:.76rem;color:var(--txt);font-family:var(--bf)}
</style>
<nav id="nav">
  <a href="/" class="nl">
    <img src="/images/logo.png" alt="Scent World Canada" style="height:40px;width:auto;object-fit:contain" onerror="this.onerror=null;this.style.display='none'">
  </a>
  <div class="nk">
    <a href="/shop">Shop</a>
    <a href="/#spaces">Industries</a>
    <a href="/#about">About</a>
    <a href="/#services">Services</a>
    <a href="/blog.html">Blog</a>
    <div class="nav-search" id="navSearch">
      <button class="nav-search-btn" onclick="document.getElementById('navSearch').classList.toggle('open');document.getElementById('navSearchInput').focus()" aria-label="Search products">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <form class="nav-search-form" action="/search" method="get">
        <div class="nav-search-row">
          <input type="search" name="q" id="navSearchInput" placeholder="Search products…" maxlength="80" autocomplete="off" required>
          <button type="submit" class="go-btn">Go</button>
        </div>
        <div class="search-suggest" id="navSearchSuggest"></div>
      </form>
    </div>
    <% if (typeof cartLive !== 'undefined' && cartLive) { %>
    <button class="cart-btn" id="cartBtn" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-badge" id="cartBadge">0</span>
    </button>
    <% } else { %>
    <a href="/#cart" class="cart-btn" id="cartBtn" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-badge" id="cartBadge">0</span>
    </a>
    <% } %>
    <a href="/#contact" class="nc">Get a Quote</a>
  </div>
  <div class="m-actions">
    <a href="tel:+19027070807" class="cart-btn" aria-label="Call us">
      <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
    </a>
    <% if (typeof cartLive !== 'undefined' && cartLive) { %>
    <button class="cart-btn" aria-label="Cart" onclick="document.getElementById('cartBtn').click()">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-badge">0</span>
    </button>
    <% } else { %>
    <a href="/#cart" class="cart-btn" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-badge">0</span>
    </a>
    <% } %>
    <button class="mb" id="mbBtn" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>
<div class="mn" id="mn">
  <button class="mc" onclick="cm()">&#10005;</button>
  <form class="mn-search" action="/search" method="get">
    <input type="search" name="q" id="mnSearchInput" placeholder="Search products…" maxlength="80" autocomplete="off" required>
    <button type="submit" aria-label="Search">→</button>
  </form>
  <div class="search-suggest mn-suggest" id="mnSearchSuggest"></div>
  <a href="/shop" onclick="cm()">Shop</a>
  <a href="/#spaces" onclick="cm()">Industries</a>
  <a href="/#about" onclick="cm()">About</a>
  <a href="/#services" onclick="cm()">Services</a>
  <a href="/blog.html" onclick="cm()">Blog</a>
  <a href="/#contact" onclick="cm()">Contact</a>
  <a href="/#booking" onclick="cm()">Book Consultation</a>
</div>
<script>
window.addEventListener('scroll', function() { var n = document.getElementById('nav'); if (n) n.classList.toggle('sc', window.scrollY > 50); });
function cm() { var m = document.getElementById('mn'); if (m) m.classList.remove('op'); }
document.getElementById('mbBtn').onclick = function() { document.getElementById('mn').classList.add('op'); };

// Live search type-ahead: debounced fetch to /api/search, render a small
// product dropdown. Shared by the desktop and mobile search inputs.
(function () {
  function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]; }); }
  function money(n) { return n == null ? '' : '$' + Number(n).toFixed(2); }
  function wire(input, box) {
    if (!input || !box) return;
    var timer, lastQ = '';
    function render(results) {
      if (!results.length) { box.innerHTML = '<div class="ss-empty">No matches — press Enter to search all.</div>'; box.classList.add('show'); return; }
      box.innerHTML = results.map(function (r) {
        return '<a href="/products/' + encodeURIComponent(r.slug) + '">' +
          '<img src="' + esc(r.image_url) + '" alt="" onerror="this.style.visibility=\'hidden\'">' +
          '<span class="ss-info"><span class="ss-name">' + esc(r.name) + '</span>' +
          '<span class="ss-meta">' + esc(r.category) + '</span></span>' +
          '<span class="ss-price">' + money(r.price) + '</span></a>';
      }).join('');
      box.classList.add('show');
    }
    input.addEventListener('input', function () {
      var q = input.value.trim();
      if (q === lastQ) return; lastQ = q;
      clearTimeout(timer);
      if (q.length < 2) { box.classList.remove('show'); box.innerHTML = ''; return; }
      timer = setTimeout(function () {
        fetch('/api/search?q=' + encodeURIComponent(q))
          .then(function (r) { return r.json(); })
          .then(function (d) { if (input.value.trim().length >= 2) render(d.results || []); })
          .catch(function () {});
      }, 180);
    });
    input.addEventListener('blur', function () { setTimeout(function () { box.classList.remove('show'); }, 160); });
    input.addEventListener('focus', function () { if (box.innerHTML) box.classList.add('show'); });
  }
  wire(document.getElementById('navSearchInput'), document.getElementById('navSearchSuggest'));
  wire(document.getElementById('mnSearchInput'), document.getElementById('mnSearchSuggest'));
})();
</script>
