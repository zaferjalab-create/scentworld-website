<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0b0908;--bg2:#12100e;--bg3:#1a1714;
  --gold:#c9a55c;--gold-l:#e0ca8e;
  --cream:#f5f0e6;--cream2:#cdc5b8;
  --txt:#958e85;--txt2:#635d55;
  --bdr:rgba(201,165,92,.1);
  --df:'Playfair Display',serif;--bf:'Outfit',sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--bf);background:var(--bg);color:var(--cream);overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:var(--gold);text-decoration:none}a:hover{text-decoration:underline}
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.3rem 4vw;display:flex;align-items:center;justify-content:space-between;background:rgba(11,9,8,.93);backdrop-filter:blur(25px);border-bottom:1px solid var(--bdr)}
.nl{display:flex;align-items:center;gap:.6rem;text-decoration:none}
.nl span{font-family:var(--df);font-size:1.2rem;color:var(--gold);letter-spacing:.06em}


.ph{padding:9rem 4vw 4rem;text-align:center;border-bottom:1px solid var(--bdr)}
.ph-label{font-size:.62rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
.ph h1{font-family:var(--df);font-size:clamp(2rem,4vw,3rem);font-weight:400;margin-bottom:.8rem}
.ph p{font-size:.82rem;color:var(--txt);font-weight:200;letter-spacing:.04em}
.policy-wrap{max-width:820px;margin:0 auto;padding:4rem 4vw 6rem}
.policy-wrap h2{font-family:var(--df);font-size:1.3rem;font-weight:500;color:var(--gold);margin:3rem 0 1rem;padding-bottom:.5rem;border-bottom:1px solid var(--bdr)}
.policy-wrap h2:first-child{margin-top:0}
.policy-wrap h3{font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--cream2);margin:1.8rem 0 .7rem;font-weight:500}
.policy-wrap p{font-size:.88rem;line-height:1.85;color:var(--cream2);margin-bottom:1rem;font-weight:300}
.policy-wrap ul{margin:.5rem 0 1rem 1.2rem}
.policy-wrap ul li{font-size:.88rem;line-height:1.85;color:var(--cream2);margin-bottom:.4rem;font-weight:300}
.policy-wrap .updated{font-size:.72rem;color:var(--txt2);letter-spacing:.06em;margin-bottom:2.5rem;padding:.6rem 1rem;border-left:2px solid var(--gold-l);background:var(--bg3)}
.info-box{background:var(--bg3);border:1px solid var(--bdr);padding:1.2rem 1.5rem;margin:1.2rem 0;border-radius:2px}
.info-box p{margin-bottom:.3rem}
.info-box p:last-child{margin-bottom:0}
footer{background:var(--bg2);border-top:1px solid var(--bdr);padding:2.5rem 4vw;text-align:center}
.fb p{font-size:.72rem;color:var(--txt2);letter-spacing:.06em}
.fb a{color:var(--txt);font-size:.72rem;letter-spacing:.06em;text-decoration:none;margin:0 .8rem}
.fb a:hover{color:var(--gold)}
.fb-links{margin-top:.7rem}
</style>
</head>
