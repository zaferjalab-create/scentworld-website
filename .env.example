# Scent World Canada — Configuration
# Copy this file to .env and fill in your values.
# On Railway, set these in the project's Variables tab instead.

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://www.scentworld.ca

# Sessions — REQUIRED in production. Random string, 32+ chars.
# Without it, admin sessions reset on every restart/redeploy.
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Admin login — used ONCE to create the admin user on first run.
# After that, change the password from the admin dashboard (Settings).
ADMIN_EMAIL=admin@scentworld.ca
ADMIN_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
# Signing secret for the webhook endpoint /api/stripe/webhook
# (Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend) — order/quote notifications, customer confirmations,
# and the nightly database backup email.
RESEND_API_KEY=re_...
NOTIFY_EMAIL=hello@scentworld.ca
