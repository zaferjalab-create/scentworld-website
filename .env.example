# Scent World Canada — Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Admin Login (change these!)
ADMIN_EMAIL=admin@scentworld.ca
ADMIN_PASSWORD=changeme123

# Email Notifications (optional — uses Gmail SMTP)
# Create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=hello@scentworld.ca

# Site
SITE_URL=https://scentworld.ca
SITE_NAME=Scent World Canada
